# Postgres connection. Dev default matches scripts/dev-db.mjs (embedded postgres).
# On GCP: point at Cloud SQL (postgres) instance.
DATABASE_URI=postgres://postgres:postgres@127.0.0.1:5502/isocodelabs

# Payload secret — generate a long random string for production.
PAYLOAD_SECRET=CHANGE_ME

# Public origin of the site (used for SEO, OG urls, sitemap).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Resend — founder notification emails on new contact/quiz/application
# submissions (src/lib/notify.ts). Without this set, notifications are
# silently skipped (the submission itself still saves fine either way).
# Sign up at resend.com, create an API key, and verify isocodelabs.com as a
# sending domain there (adds a few DNS records) before RESEND_FROM_EMAIL below
# will actually deliver.
RESEND_API_KEY=
# Must be on a domain verified in Resend. Defaults to this if unset.
RESEND_FROM_EMAIL=Isocode Notifications <notifications@isocodelabs.com>
